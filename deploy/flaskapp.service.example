[Unit]
Description=Grid Social Flask app (gunicorn)
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/opt/grid-social/backend
Environment="PATH=/opt/grid-social/backend/.venv/bin"
EnvironmentFile=/opt/grid-social/backend/.env
ExecStart=/opt/grid-social/backend/.venv/bin/gunicorn -w 3 -b 127.0.0.1:8000 wsgi:application
Restart=always

[Install]
WantedBy=multi-user.target
